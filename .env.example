# Variabili d'ambiente — copia in .env e compila i valori

# Flask
FLASK_SECRET_KEY=cambia-questa-chiave-segreta
FLASK_SQLALCHEMY_DATABASE_URI=sqlite:///local.db  # oppure libsql://...

# Google OAuth2 (https://console.cloud.google.com/)
FLASK_GOOGLE_CLIENT_ID=
FLASK_GOOGLE_CLIENT_SECRET=

# Turso (https://turso.tech/)
TURSO_URL=libsql://<db-name>.turso.io
TURSO_AUTH_TOKEN=

# FTP Hosting
FTP_HOST=ftp.example.com
FTP_USER=utente_ftp
FTP_PASS=password_ftp
FTP_PATH=/public_html

# Cloudinary (storage immagini — alternativa a Google Drive)
# Formato: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

# Accesso backoffice (email Google autorizzata)
ALLOWED_EMAIL=artista@example.com
